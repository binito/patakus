DATABASE_URL="mysql://USER:STRONG_PASSWORD@localhost:3306/patakus"
JWT_SECRET="use_openssl_rand_hex_64_to_generate"
JWT_ACCESS_EXPIRES_IN="15m"   # access token — curto; não alterar sem razão
PORT=3001
UPLOAD_DIR="./uploads"

# Obrigatórias — servidor não arranca sem estas
ALLOWED_ORIGINS="http://localhost:3000,https://yourdomain.com"
FRONTEND_URL=https://yourdomain.com
SEED_ADMIN_PASSWORD="strong_admin_password"

# Opcional — Sentry error tracking (https://sentry.io, free tier)
# SENTRY_DSN=https://xxxxx@oXXXX.ingest.sentry.io/XXXX
